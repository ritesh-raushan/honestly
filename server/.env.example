# Environment (development | production)
ENVIRONMENT=development

# Database Settings
DATABASE_HOSTNAME=localhost
DATABASE_PORT=5432
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=honestly
DATABASE_USERNAME=postgres

# JWT Settings
SECRET_KEY=your_access_token_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_SECRET_KEY=your_refresh_token_secret_key
REFRESH_TOKEN_EXPIRE_DAYS=7
VERIFICATION_TOKEN_EXPIRE_HOURS=1
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# Email Settings (Resend SMTP)
RESEND_API_KEY=your_resend_api_key
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=Anonymous Feedback

# URL Settings
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
